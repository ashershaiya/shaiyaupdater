<Window x:Name="Window1" x:Class="Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Updater"
        mc:Ignorable="d"
        Title="Shaiya Updater" Height="700" Width="1180" ResizeMode="NoResize" WindowStyle="None" MouseLeftButtonDown="Window1_MouseLeftButtonDown" WindowStartupLocation="CenterScreen" Initialized="Window1_Initialized" Loaded="Window1_Loaded" Background="{x:Null}" AllowsTransparency="True">
    
    <Window.Resources>
        <!-- Settings CheckBox Style -->
        <Style x:Key="SettingsCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="bd" Width="18" Height="18" Background="#111116" BorderBrush="#33333C" BorderThickness="1" CornerRadius="2">
                                <Border x:Name="inner" Width="10" Height="10" Background="#2BD25F" CornerRadius="1" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="inner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2BD25F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings RadioButton Style -->
        <Style x:Key="SettingsRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="bd" Width="18" Height="18" Background="#111116" BorderBrush="#33333C" BorderThickness="1" CornerRadius="2">
                                <Border x:Name="inner" Width="10" Height="10" Background="#2BD25F" CornerRadius="1" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="15,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="inner" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2BD25F"/>
                                <Setter Property="Foreground" Value="#33B5E5"/> <!-- Slightly lighter blue text for selected resolution like the screenshot? Actually screenshot text looks white. Let's use white. -->
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress bar orange style -->
        <Style x:Key="OrangeProgressBar" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="#33FFFFFF" CornerRadius="0" Height="{TemplateBinding Height}"/>
                            <Border x:Name="PART_Track" CornerRadius="0" Height="{TemplateBinding Height}"/>
                            <Border x:Name="PART_Indicator" CornerRadius="0" Height="{TemplateBinding Height}" HorizontalAlignment="Left">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FFCC5500" Offset="0"/>
                                        <GradientStop Color="#FFFF6600" Offset="0.5"/>
                                        <GradientStop Color="#FFEE5500" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar icon button style -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#33000000"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#88FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#E66542"/>
                                <Setter TargetName="bd" Property="Background" Value="#11FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tag label style -->
        <Style x:Key="TagStyle" TargetType="Border">
            <Setter Property="Background" Value="#44000000"/>
            <Setter Property="BorderBrush" Value="#55FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="10,4,10,4"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- Top bar icon button -->
        <Style x:Key="TopBarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat PLAY button style matching website UI -->
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" Background="#B83A14" BorderThickness="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#D6481A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#992C0E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#2A2A30"/>
                                <Setter Property="Foreground" Value="#66FFFFFF"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Settings Button Style -->
        <Style x:Key="SettingsButtonStyle" TargetType="Button" BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <Path Data="M19.4,13c0-0.2,0-0.4,0-0.5s0-0.4,0-0.5l2.1-1.6c0.2-0.2,0.3-0.4,0.2-0.6l-2-3.5C19.6,6.1,19.4,6,19.2,6.1l-2.5,1 c-0.5-0.4-1.1-0.7-1.7-1l-0.4-2.6C14.5,3.2,14.3,3,14,3h-4C9.7,3,9.5,3.2,9.5,3.5L9.1,6.1C8.5,6.4,7.9,6.7,7.4,7.1L4.9,6.1 C4.7,6,4.5,6.1,4.4,6.3l-2,3.5C2.3,10,2.3,10.2,2.5,10.4l2.1,1.6c0,0.2,0,0.4,0,0.5s0,0.4,0,0.5l-2.1,1.6c-0.2,0.2-0.3,0.4-0.2,0.6 l2,3.5c0.1,0.2,0.3,0.3,0.5,0.2l2.5-1c0.5,0.4,1.1,0.7,1.7,1l0.4,2.6c0,0.2,0.2,0.4,0.5,0.4h4c0.3,0,0.5-0.2,0.5-0.5l0.4-2.6 c0.6-0.3,1.2-0.6,1.7-1l2.5,1c0.2,0.1,0.4,0,0.5-0.2l2-3.5c0.1-0.2,0.1-0.4-0.1-0.6L19.4,13z M12,15.5c-1.9,0-3.5-1.6-3.5-3.5 s1.6-3.5,3.5-3.5s3.5,1.6,3.5,3.5S13.9,15.5,12,15.5z" Fill="{TemplateBinding Foreground}" Stretch="Uniform" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimize Button Style -->
        <Style x:Key="MinimizeButtonStyle" TargetType="Button" BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <Path Data="M 0,0 L 11,0" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TopBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login Button Style -->
        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="bd" Background="#2C2C3A" BorderThickness="1" BorderBrush="#55FFFFFF">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" Fill="White" Stretch="Uniform" Width="14" Height="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="LOGIN" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A4C"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#222230"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login Form TextBox Style -->
        <Style x:Key="LoginTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#18181E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#33333C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,8,10,8"/>
                                <TextBlock x:Name="placeholder" Text="Username" Foreground="#55FFFFFF" FontSize="14" FontFamily="Segoe UI" 
                                           VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login Form PasswordBox Style -->
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#18181E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#33333C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="10,8,10,8"/>
                                <TextBlock x:Name="placeholder" Text="Password" Foreground="#55FFFFFF" FontSize="14" FontFamily="Segoe UI" 
                                           VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Login Action Button Style (LOGIN / CREATE ACCOUNT) -->
        <Style x:Key="LoginActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main container with background image -->
    <Grid x:Name="Grid1" Height="700" Width="1180" ClipToBounds="True">
        <Grid.Background>
            <ImageBrush x:Name="BackgroundBrush" Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Dark gradient overlay for readability -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#DD111118" Offset="0"/>
                    <GradientStop Color="#88111118" Offset="0.35"/>
                    <GradientStop Color="#22111118" Offset="0.55"/>
                    <GradientStop Color="#00000000" Offset="0.7"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                    <GradientStop Color="#CC111118" Offset="0"/>
                    <GradientStop Color="#44111118" Offset="0.15"/>
                    <GradientStop Color="#00000000" Offset="0.35"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <!-- Top edge gradient -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#AA111118" Offset="0"/>
                    <GradientStop Color="#00000000" Offset="0.08"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ============================================ -->
        <!-- TOP BAR -->
        <!-- ============================================ -->
        <DockPanel Height="40" VerticalAlignment="Top" Margin="0,0,0,0" LastChildFill="False">
            <!-- Top bar background -->
            <DockPanel.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#88000000" Offset="0"/>
                    <GradientStop Color="#44000000" Offset="1"/>
                </LinearGradientBrush>
            </DockPanel.Background>

            <!-- Logo area - left -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" Margin="12,0,0,0" VerticalAlignment="Center">
                <!-- Shaiya logo icon placeholder -->
                <TextBlock Text="⚔" FontSize="20" Foreground="#FFCC6600" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="S H A I Y A" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Right side buttons -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,8,0" VerticalAlignment="Center">
                <!-- Status indicator placeholder -->
                <Border Background="#33000000" CornerRadius="4" Padding="10,4" Margin="0,0,12,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ServerStatusDot" Width="8" Height="8" Fill="#666666" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ServerStatusText" Text="CHECKING..." FontSize="11" Foreground="#999999" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Border>

                <!-- Login button (visible when NOT logged in) -->
                <Button x:Name="LoginButton" Cursor="Hand" Margin="0,0,12,0" VerticalAlignment="Center" Click="LoginButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="Transparent" Padding="6,4,6,4">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M15 3H5c-1.1 0-2 .9-2 2v4c0 1.1.9 2 2 2h1v2c0 1.1.9 2 2 2h3l3 3v-3h1c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" Fill="#CCFFFFFF" Stretch="Uniform" Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Log In" FontSize="12" Foreground="#CCFFFFFF" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Logged-in user panel (visible when logged in) -->
                <Button x:Name="LoggedInPanelButton" Visibility="Collapsed" Cursor="Hand" Margin="0,0,12,0" VerticalAlignment="Center" Click="ProfileDropdownButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="loggedInBd" Background="#33000000" CornerRadius="4" Padding="8,4">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="loggedInBd" Property="Background" Value="#55000000"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <!-- Username -->
                        <TextBlock x:Name="LoggedInUsername" Text="" FontSize="12" Foreground="#DDDDDD" VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <!-- Gold coin icon + points -->
                        <Ellipse Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,4,0">
                            <Ellipse.Fill>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFD700" Offset="0"/>
                                    <GradientStop Color="#DAA520" Offset="0.7"/>
                                    <GradientStop Color="#B8860B" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock x:Name="LoggedInPoints" Text="0" FontSize="12" Foreground="#DDDDDD" VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,8,0"/>
                        <!-- Faction icon -->
                        <Image x:Name="FactionIcon" Width="22" Height="22" VerticalAlignment="Center" Stretch="Uniform"/>
                    </StackPanel>
                </Button>

                <!-- Settings gear -->
                <Button x:Name="SettingsButton" Style="{StaticResource SettingsButtonStyle}" Margin="0,0,4,0" Click="SettingsButton_Click"/>
                <!-- Minimize button -->
                <Button x:Name="MinimizeButton" Style="{StaticResource MinimizeButtonStyle}" Margin="0,0,4,0" Click="MinimizeButton_Click"/>
                <!-- Close Button (Button1) - PRESERVED logic, new style -->
                <Button x:Name="Button1" Style="{StaticResource CloseButtonStyle}" Click="Button1_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- ============================================ -->
        <!-- LEFT SIDE CONTENT OVERLAY -->
        <!-- ============================================ -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="30,60,0,0" Width="320">
            <!-- Shaiya Logo Image -->
            <Image Source="https://i.imgur.com/biV9wmG.png" Stretch="Uniform" HorizontalAlignment="Left" Width="180" Margin="-5,-20,0,10"/>

            <!-- Description -->
            <TextBlock Text="Shaiya is a free-to-play fantasy MMORPG from Nexon and Aeria Games set in a world at war between the forces of Light and Darkness." 
                       Foreground="#CCDDDDDD" FontSize="12.5" TextWrapping="Wrap" LineHeight="18" FontFamily="Segoe UI" Margin="0,0,0,14"/>

            <!-- Genre tags -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Style="{StaticResource TagStyle}">
                    <TextBlock Text="Fantasy" Foreground="#CCFFFFFF" FontSize="11" FontFamily="Segoe UI"/>
                </Border>
                <Border Style="{StaticResource TagStyle}">
                    <TextBlock Text="MMORPG" Foreground="#CCFFFFFF" FontSize="11" FontFamily="Segoe UI"/>
                </Border>
                <Border Style="{StaticResource TagStyle}">
                    <TextBlock Text="PvP / PvE" Foreground="#CCFFFFFF" FontSize="11" FontFamily="Segoe UI"/>
                </Border>
            </StackPanel>

            <!-- Discord + Website buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                <!-- Join Discord button -->
                <Button x:Name="DiscordButton" Cursor="Hand" Margin="0,0,8,0" Click="DiscordButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="discordBorder" Background="#22000000" CornerRadius="1" Padding="14,6,14,6" BorderThickness="1" BorderBrush="White">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M 12.5,2.5 C 11.5,2.1 10.4,1.8 9.2,1.6 C 9.1,1.9 8.9,2.2 8.8,2.5 C 7.6,2.3 6.4,2.3 5.2,2.5 C 5.1,2.2 4.9,1.9 4.8,1.6 C 3.6,1.8 2.5,2.1 1.5,2.5 C -0.5,5.5 -1.0,8.5 -0.5,11.5 C 0.8,12.5 2.1,13.1 3.4,13.5 C 3.7,13.1 4.0,12.7 4.2,12.3 C 3.8,12.1 3.3,11.9 2.9,11.6 C 3.0,11.5 3.1,11.4 3.2,11.3 C 5.8,12.5 8.2,12.5 10.8,11.3 C 10.9,11.4 11.0,11.5 11.1,11.6 C 10.7,11.9 10.2,12.1 9.8,12.3 C 10.0,12.7 10.3,13.1 10.6,13.5 C 11.9,13.1 13.2,12.5 14.5,11.5 C 15.0,8.5 14.5,5.5 12.5,2.5 Z" Fill="White" Stretch="Uniform" Width="18" Height="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="JOIN DISCORD" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="discordBorder" Property="Background" Value="#44FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="discordBorder" Property="Background" Value="#66FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <!-- Website button -->
                <Button x:Name="WebsiteButton" Cursor="Hand" Click="WebsiteButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="webBorder" Background="#22000000" CornerRadius="1" Padding="12,6,12,6" BorderThickness="1" BorderBrush="White">
                                <StackPanel Orientation="Horizontal">
                                    <Canvas Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse Width="14" Height="14" Canvas.Left="1" Canvas.Top="1" Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                        <Ellipse Width="6" Height="14" Canvas.Left="5" Canvas.Top="1" Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                        <Line X1="1" Y1="8" X2="15" Y2="8" Stroke="White" StrokeThickness="1.5"/>
                                        <Line X1="2.5" Y1="4" X2="13.5" Y2="4" Stroke="White" StrokeThickness="1.5"/>
                                        <Line X1="2.5" Y1="12" X2="13.5" Y2="12" Stroke="White" StrokeThickness="1.5"/>
                                    </Canvas>
                                    <TextBlock Text="VISIT WEBSITE" FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="webBorder" Property="Background" Value="#44FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="webBorder" Property="Background" Value="#66FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>



        <!-- ============================================ -->
        <!-- RIGHT SIDEBAR ICONS -->
        <!-- ============================================ -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,40,20,40" Width="52">
            <!-- Trophy -->
            <Button x:Name="RankingButton" Click="RankingButton_Click" Style="{StaticResource SidebarButtonStyle}" Margin="0,0,0,12" HorizontalAlignment="Center">
                <Path Data="M19 2H5C3.34 2 2 3.34 2 5v2c0 1.66 1.34 3 3 3h1.18c.53 1.92 2.14 3.44 4.14 3.91V19H8v2h8v-2h-2.32c2-.47 3.61-1.99 4.14-3.91H19c1.66 0 3-1.34 3-3V5c0-1.66-1.34-3-3-3zM5 8V4h2v4H5zm14 0h-2V4h2v4z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="14" Height="14"/>
            </Button>

            <!-- Bag -->
            <Button x:Name="DropsButton" Click="DropsButton_Click" Style="{StaticResource SidebarButtonStyle}" Margin="0,0,0,12" HorizontalAlignment="Center">
                <Path Data="M12 2c-2.21 0-4 1.79-4 4v2H6c-1.1 0-2 .9-2 2v9c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-9c0-1.1-.9-2-2-2h-2V6c0-2.21-1.79-4-4-4zm0 2c1.1 0 2 .9 2 2v2h-4V6c0-1.1.9-2 2-2zm-2 9v-2h4v2h-4z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="12" Height="14"/>
            </Button>
            <!-- Menu -->
            <Button x:Name="BossesButton" Click="BossesButton_Click" Style="{StaticResource SidebarButtonStyle}" Margin="0,0,0,0" HorizontalAlignment="Center">
                <Path Data="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="14" Height="12"/>
            </Button>
        </StackPanel>

        <!-- ============================================ -->
        <!-- WEBBROWSER (hidden behind news, preserved) -->
        <!-- ============================================ -->
        <WebBrowser x:Name="WebBrowser1" Margin="10,44,56,65" Focusable="False" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Panel.ZIndex="-1" Visibility="Hidden"/>

        <!-- ============================================ -->
        <!-- BOTTOM STATUS BAR -->
        <!-- ============================================ -->
        <Border VerticalAlignment="Bottom" Height="58" Background="#DD0D0D12" BorderThickness="0,1,0,0" BorderBrush="#33FFFFFF">
            <Grid Margin="20,0,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>




                <!-- Center: Progress area -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="380">
                    <!-- Status text -->
                    <TextBox x:Name="TextBox1" TextWrapping="Wrap" IsReadOnly="True" Height="18" 
                             TextAlignment="Center" IsTabStop="False" AllowDrop="False" Focusable="False" 
                             IsUndoEnabled="False" Background="{x:Null}" BorderBrush="{x:Null}" 
                             SelectionBrush="{x:Null}" SelectionTextBrush="{x:Null}" Foreground="#CCFFFFFF" 
                             BorderThickness="0" ClipToBounds="True" SelectionOpacity="0" IsEnabled="False"
                             FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,3"/>
                    <!-- Progress bars stacked -->
                    <Grid Height="7">
                        <ProgressBar x:Name="ProgressBar2" Style="{StaticResource OrangeProgressBar}" 
                                     Height="7" IsTabStop="False" Value="100" Margin="0"/>
                    </Grid>
                    <Grid Height="5" Margin="0,2,0,0">
                        <ProgressBar x:Name="ProgressBar1" Style="{StaticResource OrangeProgressBar}" 
                                     Height="5" IsTabStop="False" Value="100" Margin="0"/>
                    </Grid>
                </StackPanel>

                <!-- PLAY / Update Button (Button2) - PRESERVED logic, new style -->
                <Button x:Name="Button2" Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" 
                        Click="Button2_Click" Style="{StaticResource PlayButtonStyle}" Content="Login required" IsEnabled="False" FontSize="13"/>
            </Grid>
        </Border>

        <!-- ============================================ -->
        <!-- SETTINGS OVERLAY -->
        <!-- ============================================ -->
        <Grid x:Name="SettingsOverlay" Visibility="Collapsed" Background="#A0000000" Panel.ZIndex="100">
            <Border Width="650" Height="400" Background="#111114" CornerRadius="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="60"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border BorderBrush="#22222A" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="SETTINGS" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="20,0,0,0"/>
                            <Button x:Name="CloseSettingsButton" Style="{StaticResource TopBarButtonStyle}" HorizontalAlignment="Right" Margin="0,0,10,0" Click="CloseSettingsButton_Click">
                                <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>
                    
                    <!-- Content -->
                    <StackPanel Grid.Row="1" Margin="20,20,20,20">
                        <!-- Tab Header -->
                        <Border Background="#2C2C3A" BorderBrush="#CC0000" BorderThickness="0,0,2,0" Width="180" HorizontalAlignment="Left" Padding="20,12,20,12" Margin="-20,0,0,20">
                            <TextBlock Text="GRAPHIC SETTINGS" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        
                        <!-- Full Screen -->
                        <Border Background="#16161D" CornerRadius="2" Padding="20,12,20,12" Margin="0,0,0,10">
                            <CheckBox x:Name="chkFullScreen" Style="{StaticResource SettingsCheckBoxStyle}" Content="Full Screen"/>
                        </Border>
                        
                        <!-- Resolutions -->
                        <Border Background="#16161D" CornerRadius="2" Padding="20,20,20,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Column 1 -->
                                <RadioButton Grid.Row="0" Grid.Column="0" Tag="1280x720" Style="{StaticResource SettingsRadioButtonStyle}" Content="1280 x 720" Margin="0,0,0,15"/>
                                <RadioButton Grid.Row="1" Grid.Column="0" Tag="1920x1080" Style="{StaticResource SettingsRadioButtonStyle}" Content="1920 x 1080" Margin="0,0,0,15"/>
                                <RadioButton Grid.Row="2" Grid.Column="0" Tag="3840x2160" Style="{StaticResource SettingsRadioButtonStyle}" Content="3840 x 2160"/>
                                
                                <!-- Column 2 -->
                                <RadioButton Grid.Row="0" Grid.Column="1" Tag="1366x768" Style="{StaticResource SettingsRadioButtonStyle}" Content="1366 x 768" Margin="0,0,0,15"/>
                                <RadioButton Grid.Row="1" Grid.Column="1" Tag="2560x1080" Style="{StaticResource SettingsRadioButtonStyle}" Content="2560 x 1080" Margin="0,0,0,15"/>
                                
                                <!-- Column 3 -->
                                <RadioButton Grid.Row="0" Grid.Column="2" Tag="1600x900" Style="{StaticResource SettingsRadioButtonStyle}" Content="1600 x 900" Margin="0,0,0,15"/>
                                <RadioButton Grid.Row="1" Grid.Column="2" Tag="2560x1440" Style="{StaticResource SettingsRadioButtonStyle}" Content="2560 x 1440" Margin="0,0,0,15"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Footer -->
                    <Border Grid.Row="2" BorderBrush="#22222A" BorderThickness="0,1,0,0">
                        <Button x:Name="SaveSettingsButton" Content="SAVE" Width="100" Height="30" HorizontalAlignment="Right" Margin="0,0,20,0" Foreground="White" Background="#B83A14" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" Click="SaveSettingsButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- LOGIN OVERLAY -->
        <!-- ============================================ -->
        <Grid x:Name="LoginOverlay" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="100">
            <Border Width="750" Height="460" Background="#1A1A22" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Panel: Artwork -->
                    <Grid Grid.Column="0" Background="#111118">
                        <Image x:Name="LoginArtwork" Stretch="UniformToFill" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>
                        <!-- Dark gradient overlay on artwork -->
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#33000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.3"/>
                                    <GradientStop Color="#22000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Rectangle>
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#88000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.4"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>

                    <!-- Right Panel: Login Form -->
                    <Grid Grid.Column="1">
                        <!-- Close button -->
                        <Button x:Name="CloseLoginButton" Style="{StaticResource TopBarButtonStyle}" 
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0" 
                                Click="CloseLoginButton_Click">
                            <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="White" StrokeThickness="1.5" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Form content -->
                        <StackPanel VerticalAlignment="Center" Margin="40,0,40,0">
                            <!-- Username -->
                            <TextBox x:Name="LoginUsername" Style="{StaticResource LoginTextBoxStyle}" Margin="0,0,0,10"/>

                            <!-- Password -->
                            <PasswordBox x:Name="LoginPassword" Style="{StaticResource LoginPasswordBoxStyle}" Margin="0,0,0,16"/>

                            <!-- Keep me logged in -->
                            <CheckBox x:Name="chkKeepLoggedIn" Style="{StaticResource SettingsCheckBoxStyle}" Content="Keep me logged in" Margin="0,0,0,24"/>

                            <!-- LOGIN Button -->
                            <Button x:Name="LoginSubmitButton" Content="LOGIN" 
                                    Style="{StaticResource LoginActionButtonStyle}" 
                                    Background="#44445A" BorderThickness="0" 
                                    Margin="0,0,0,10" Click="LoginSubmitButton_Click"/>

                            <!-- CREATE ACCOUNT Button -->
                            <Button x:Name="CreateAccountButton" Content="CREATE ACCOUNT" 
                                    Style="{StaticResource LoginActionButtonStyle}" 
                                    Background="Transparent" BorderBrush="#55FFFFFF" BorderThickness="1" 
                                    Margin="0,0,0,0" Click="CreateAccountButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================================ -->
        <!-- PROFILE DROPDOWN POPUP -->
        <!-- ============================================ -->
        <Popup x:Name="ProfileDropdownPopup" PlacementTarget="{Binding ElementName=LoggedInPanelButton}" 
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade"
               HorizontalOffset="-10" VerticalOffset="4">
            <Border Background="#22222C" BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="6" Padding="4,6" MinWidth="155">
                <StackPanel>
                    <!-- User Panel -->
                    <Button x:Name="UserPanelButton" Cursor="Hand" Click="UserPanelButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="14,8,14,8" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="User Panel" FontSize="13" Foreground="#DDDDDD" VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,6,0"/>
                                        <!-- External link icon -->
                                        <Canvas Width="12" Height="12" VerticalAlignment="Center">
                                            <Path Data="M3 3 L3 13 L13 13 L13 8" Stroke="#888888" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M7 1 L13 1 L13 7" Stroke="#888888" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M13 1 L6 8" Stroke="#888888" StrokeThickness="1.5"/>
                                        </Canvas>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Donate -->
                    <Button x:Name="DonateButton" Cursor="Hand" Click="DonateButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="14,8,14,8" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Donate" FontSize="13" Foreground="#DDDDDD" VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,6,0"/>
                                        <!-- External link icon -->
                                        <Canvas Width="12" Height="12" VerticalAlignment="Center">
                                            <Path Data="M3 3 L3 13 L13 13 L13 8" Stroke="#888888" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M7 1 L13 1 L13 7" Stroke="#888888" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M13 1 L6 8" Stroke="#888888" StrokeThickness="1.5"/>
                                        </Canvas>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Separator -->
                    <Border Height="1" Background="#33FFFFFF" Margin="6,4,6,4"/>
                    <!-- Log Out -->
                    <Button x:Name="LogOutButton" Cursor="Hand" Click="LogOutButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="Transparent" Padding="14,8,14,8" CornerRadius="4">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Log Out" FontSize="13" Foreground="#E53935" FontWeight="SemiBold" VerticalAlignment="Center" FontFamily="Segoe UI" Margin="0,0,6,0"/>
                                        <!-- External link icon (red) -->
                                        <Canvas Width="12" Height="12" VerticalAlignment="Center">
                                            <Path Data="M3 3 L3 13 L13 13 L13 8" Stroke="#E53935" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M7 1 L13 1 L13 7" Stroke="#E53935" StrokeThickness="1.5" Fill="Transparent"/>
                                            <Path Data="M13 1 L6 8" Stroke="#E53935" StrokeThickness="1.5"/>
                                        </Canvas>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>

</Window>
